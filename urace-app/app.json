{
  "expo": {
    "name": "urace-app-frontend",
    "slug": "urace-app-frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Urace.png",
    "scheme": "uraceappfrontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ducanhnguyennn.uraceappfrontend",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/Urace.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.ducanhnguyennn.uraceappfrontend",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDnzXWC0yaODImBwsCiFv5CHSPHYB-Yz1g"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/Urace.png",
      "bundler": "metro",
      "display": "standalone",
      "backgroundColor": "#ffffff",
      "description": "URaceee"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Urace.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow URace to use your location to track your runs.",
          "locationAlwaysPermission": "Allow URace to use your location to track your runs.",
          "locationWhenInUsePermission": "Allow URace to use your location to track your runs."
        }
      ],
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8607708f-045c-4676-8158-745a2d38ae68"
      }
    },
    "owner": "ducanhnguyennn",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/8607708f-045c-4676-8158-745a2d38ae68"
    }
  }
}
