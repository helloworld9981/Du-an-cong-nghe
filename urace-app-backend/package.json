{
  "name": "urace",
  "version": "1.0.0",
  "description": "strava integration app",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "nodemon --watch src -e ts --exec ts-node src/app.ts",
    "worker": "ts-node src/workers/start-activity-worker.ts",
    "worker:dev": "nodemon --watch src -e ts --exec ts-node src/workers/start-activity-worker.ts",
    "reminder-consumer": "ts-node src/workers/start-reminder-consumer.ts",
    "reminder-consumer:dev": "nodemon --watch src -e ts --exec ts-node src/workers/start-reminder-consumer.ts",
    "typecheck": "tsc --noEmit",
    "create-activity": "ts-node src/scripts/create-manual-activity.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "huynguyen411",
  "license": "ISC",
  "devDependencies": {
    "@types/axios": "^0.14.4",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/mongodb": "^4.0.7",
    "@types/node": "^22.15.3",
    "@types/node-cron": "^3.0.11",
    "@types/redis": "^4.0.11",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.18",
    "@types/nodemailer": "^6.4.17",
    "axios": "^1.9.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-winston": "^4.2.0",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.16.0",
    "ngrok": "^5.0.0-beta.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.5",
    "querystring": "^0.2.1",
    "redis": "^5.0.1",
    "socket.io": "^4.8.3",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  }
}
